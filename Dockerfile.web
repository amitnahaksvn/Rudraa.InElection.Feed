# Identical to the root Dockerfile except the ARG default below - exists only because Render's
# Blueprint spec (render.yaml) has no field for passing --build-arg at all (confirmed against
# https://render.com/schema/render.yaml.json - dockerBuildArgs is not a real property, despite
# being a plausible-sounding name), so the two services this repo builds (Worker/Web) can't share
# one Dockerfile the way `docker build --build-arg PROJECT=...` and docker-compose.yml both do.
# The root Dockerfile (ARG PROJECT=Worker) still covers local `docker build`/docker-compose/Worker
# on Render; this file exists solely so Render's Web service has a Dockerfile that defaults to
# building Web instead, with no build-arg mechanism required.
ARG PROJECT=Web

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
ARG PROJECT
WORKDIR /src

COPY Rudraa.InElection.RSSFeed.slnx ./
COPY src/Domain/Domain.csproj src/Domain/
COPY src/Application/Application.csproj src/Application/
COPY src/Infrastructure/Infrastructure.csproj src/Infrastructure/
COPY src/ServiceDefaults/ServiceDefaults.csproj src/ServiceDefaults/
COPY src/Worker/Worker.csproj src/Worker/
COPY src/Web/Web.csproj src/Web/
RUN dotnet restore "src/${PROJECT}/${PROJECT}.csproj"

COPY src/ src/
RUN dotnet publish "src/${PROJECT}/${PROJECT}.csproj" -c Release -o /app --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app
COPY --from=build /app .

ARG PROJECT
ENV DOTNET_EnableDiagnostics=0
ENV PROJECT_DLL="${PROJECT}.dll"
ENTRYPOINT ["sh", "-c", "dotnet ${PROJECT_DLL}"]
